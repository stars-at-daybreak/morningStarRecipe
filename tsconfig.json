{
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "jsx": "react-jsx",
        "strict": true,
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true, // 이 옵션 추가
        "noEmit": true, // allowImportingTsExtensions 사용 시 필수
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src/**/*"]
}
